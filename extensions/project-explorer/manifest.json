{
  "id": "com.nimbalyst.project-explorer",
  "name": "Project Explorer",
  "version": "0.1.0",
  "description": "Browse your project structure and read AI-drafted descriptions of what each file and folder does.",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.explorer"],
        "displayName": "Project Explorer",
        "component": "ProjectExplorerEditor",
        "showDocumentHeader": false
      }
    ],
    "newFileMenu": [
      {
        "extension": ".explorer",
        "displayName": "Project Explorer",
        "icon": "account_tree",
        "defaultContent": "{\n  \"version\": 1,\n  \"root\": \".\",\n  \"descriptions\": {}\n}\n"
      }
    ],
    "fileIcons": {
      "*.explorer": "account_tree"
    },
    "aiTools": ["projectexplorer.get_overview", "projectexplorer.set_descriptions"]
  }
}
